# Local Environment Variables for Frontend
# Copy this file to .env.local and fill in your values
# Reference: docs/Intrucciones_para_crear_app_web/DOC-04 (Security + JWT)
#
# ⚠️ CRITICAL: All secrets must be changed for production
# Use: openssl rand -hex 32 to generate secure keys

# Backend API URL
# In development with Docker: http://backend:4000
# In local dev without Docker: http://127.0.0.1:5000
BACKEND_URL=http://127.0.0.1:5000

# App Configuration
NEXT_PUBLIC_APP_NAME=Cermont S.A.S.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ SECURITY CHECKLIST FOR PRODUCTION:
# - [ ] BACKEND_URL: Use production backend URL
# - [ ] NEXT_PUBLIC_APP_URL: Use HTTPS URL of production frontend
# - [ ] Rotate secrets regularly
# ─────────────────────────────────────────────────────────────────────────────
