# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend proxy — consumed by next.config.ts rewrite
# Dev: http://127.0.0.1:5000 (default, auto-detected)
# Docker: http://backend:4000 (injected by docker-compose.yml)
# BACKEND_URL=http://127.0.0.1:5000

# Refresh token verification (server-only)
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars

# App Configuration
NEXT_PUBLIC_APP_NAME=Cermont S.A.S.
NEXT_PUBLIC_APP_URL=http://localhost:3000
