# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose Environment Variables — CERMONT S.A.S.
# Copy this file to .env at the root of the monorepo before running
#   docker compose up
# WARNING: Generate unique secrets for production. DO NOT use these placeholders.
# Generate secrets with: openssl rand -base64 48
# ──────────────────────────────────────────────────────────────────────────────

# ── Required (docker compose will fail without these) ─────────────────────────
JWT_SECRET=<generate-with-openssl-rand-base64-48>
REFRESH_TOKEN_SECRET=<generate-with-openssl-rand-base64-48>
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<generate-with-openssl-rand-base64-48>

# ── Optional (have sensible defaults) ─────────────────────────────────────────
NODE_ENV=production
MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/cermont?authSource=admin
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://backend:4000
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
LOG_LEVEL=info
