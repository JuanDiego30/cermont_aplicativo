# Backend Environment Variables
# Copy this file to .env and fill in your values
# Reference: docs/Intrucciones_para_crear_app_web/DOC-04 (Security + JWT)
#
# ⚠️ CRITICAL: All secrets must be changed for production
# Use: openssl rand -hex 32 to generate secure keys

# Server Configuration
NODE_ENV=development
PORT=5000

# Database (MongoDB)
# IMPORTANT: Use 127.0.0.1 instead of localhost (Node 22+ IPv6 issue)
# Production: Use MongoDB Atlas with authentication
MONGO_ROOT_USER=change_me_dbuser
MONGO_ROOT_PASSWORD=change_me_STRONG_PASSWORD_min_16_chars
MONGODB_URI=mongodb://127.0.0.1:27017/cermont

# Seed script password (required by backend/src/scripts/seed.ts)
SEED_DEFAULT_PASSWORD=change_me_seed_password_min_16_chars

# JWT Configuration (DOC-04 §12: Token Management)
# Access token (short-lived, in memory only on client)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m

# Refresh token (long-lived, persisted in httpOnly cookie)
REFRESH_TOKEN_SECRET=your-refresh-secret-key-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS - Frontend URL (DOC-04 §3: CORS)
FRONTEND_URL=http://localhost:3000

# File Upload (DOC-04 §9: Secure uploads)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ClamAV Malware Scanning (DOC-04 §9: Secure uploads)
# Set to 'true' when ClamAV daemon is running on localhost:3310
CLAMAV_ENABLED=false

# Logging (DOC-03: Logging)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ SECURITY CHECKLIST FOR PRODUCTION:
# - [x] JWT_SECRET: Generate with openssl rand -hex 32
# - [x] REFRESH_TOKEN_SECRET: Generate with openssl rand -hex 32
# - [x] NODE_ENV: Set to "production"
# - [x] MONGODB_URI: Use MongoDB Atlas with strong password
# - [x] FRONTEND_URL: Use HTTPS URL of production frontend
# - [x] LOG_LEVEL: Set to "warn" or "error"
# - [x] Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# - [x] Rotate secrets regularly
# ─────────────────────────────────────────────────────────────────────────────
