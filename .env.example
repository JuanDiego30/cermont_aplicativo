# ─────────────────────────────────────────────────────────────────────────────
# CERMONT S.A.S. — Monorepo Environment Variables Template
# Copy this file to appropriate location:
#  - Backend: cp .env.example apps/backend/.env
#  - Frontend: cp .env.example apps/frontend/.env.local
#  - Root (monorepo): Generally not needed unless using workspace-level config
#
# Reference:
#  - DOC-04: Security, Autenticación JWT y RBAC
#  - DOC-05: Frontend Next.js 16, TanStack Query v5 y Zustand
#  - DOC-08: Despliegue y DevOps Docker, CI/CD
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND: apps/backend
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=5000

# MongoDB connection credentials (DOC-03: Mongoose + MongoDB)
# REQUIRED for docker-compose. Generate strong password: openssl rand -hex 16
MONGO_ROOT_USER=change_me_dbuser
MONGO_ROOT_PASSWORD=change_me_STRONG_PASSWORD_min_16_chars

# MongoDB connection string (DOC-03: Mongoose + MongoDB)
# For local development: mongodb://127.0.0.1:27017/cermont
# For Docker: Uses MONGO_ROOT_USER and MONGO_ROOT_PASSWORD above
MONGODB_URI=mongodb://127.0.0.1:27017/cermont

# Seed script default user password
# REQUIRED for database seeding — generate with: openssl rand -hex 16 | base64
SEED_DEFAULT_PASSWORD=change_me_seed_password_min_16_chars

# JWT Configuration (DOC-04 §12: Token Management)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-key-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS (DOC-04 §3: CORS Configuration)
FRONTEND_URL=http://localhost:3000

# File Upload (DOC-04 §9: Secure File Upload)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging (DOC-03: Structured Logging)
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND: apps/frontend
# ═══════════════════════════════════════════════════════════════════════════════

# Backend proxy — consumed by next.config.ts rewrite
# Dev: http://127.0.0.1:5000 (default, auto-detected)
# Docker: http://backend:4000 (injected by docker-compose.yml)
# BACKEND_URL=http://127.0.0.1:5000

# Application Configuration
NEXT_PUBLIC_APP_NAME=Cermont S.A.S.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monitoring (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# Feature Flags (optional)
# NEXT_PUBLIC_FEATURE_MFA_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ SECURITY CHECKLIST FOR PRODUCTION:
# ─────────────────────────────────────────────────────────────────────────────
# BACKEND:
#  ☐ JWT_SECRET: Generate with: openssl rand -hex 32
#  ☐ REFRESH_TOKEN_SECRET: Generate with: openssl rand -hex 32
#  ☐ NODE_ENV: Set to "production"
#  ☐ MONGODB_URI: Use MongoDB Atlas with strong password
#  ☐ FRONTEND_URL: Use HTTPS URL
#  ☐ Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# FRONTEND:
#  ☐ BACKEND_URL: Set to production backend URL if not using Docker
#  ☐ NEXT_PUBLIC_APP_URL: Use HTTPS URL
#  ☐ NO secrets in NEXT_PUBLIC_* variables (all exposed to browser)
#
# DEPLOYMENT:
#  ☐ Never commit .env files to git (use .gitignore)
#  ☐ Rotate secrets regularly (at least quarterly)
#  ☐ Use environment variables from CI/CD pipeline
# ─────────────────────────────────────────────────────────────────────────────
